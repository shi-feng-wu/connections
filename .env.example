# Discord
# Application (client) ID. Goes to the browser, so it needs the VITE_ prefix.
VITE_DISCORD_CLIENT_ID=your-application-id
# Optional: large image for the Rich Presence profile card. A public image URL
# (Discord fetches it server-side, so it must be the real host — not the in-Activity
# discordsays proxy) or an uploaded Art Asset key (Developer Portal -> Rich Presence
# -> Art Assets). Point it at /connections-icon.png on your production host. Unset =
# the profile card renders without a large image. VITE_ prefix: it's used in the browser.
# VITE_RP_ICON_URL=https://your-project.vercel.app/connections-icon.png
# OAuth2 client secret. Server-side only.
DISCORD_CLIENT_SECRET=your-client-secret-here

# Bot token (Developer Portal -> Bot): used by the setup scripts (register-commands,
# configure-install) AND at runtime by the daily recap cron (/api/cron-recap), which
# posts the recap as the bot to the room's last-played channel. Set it in Vercel too.
DISCORD_BOT_TOKEN=your-bot-token
# App public key (Developer Portal -> General Information): verifies the signed
# interaction webhook (/api/interactions) that turns the recap's Play button into
# an activity launch.
DISCORD_PUBLIC_KEY=your-app-public-key
# Optional: overrides the OAuth redirect for the recap install flow
# (/api/install -> /api/discord-callback). Unset = derived from the request host as
# https://<host>/api/discord-callback. Set only if that derived value isn't the one
# registered under OAuth2 -> Redirects (e.g. a custom domain). Must match exactly.
# OAUTH_REDIRECT_URI=https://your-project.vercel.app/api/discord-callback

# Supabase
# anon key is safe to ship; RLS makes it read-only.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# No VITE_ prefix: these must never reach the browser.
# service_role key writes verified scores; JWT secret signs Realtime presence tokens.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Server signing
# HMAC key for the signed game session that anchors solve timing. Any long
# random string, e.g. `openssl rand -base64 32`.
SESSION_SECRET=your-random-session-secret

# Cron
# Guards /api/cron-recap; the Supabase pg_cron job (supabase/recap-cron.sql) sends it as
# `Authorization: Bearer $CRON_SECRET` on scheduled runs. Store the SAME value in Supabase
# Vault as `cron_secret`. Any long random string, e.g. `openssl rand -base64 32`.
CRON_SECRET=your-random-cron-secret
# Your deployment's recap endpoint; only the test-recap script uses it.
# RECAP_URL=https://your-project.vercel.app/api/cron-recap

# Feedback
# Optional: where the in-game "Send feedback" form delivers notes (/api/feedback relays to
# it server-side). Make an incoming webhook in YOUR server: a channel's Edit Channel ->
# Integrations -> Webhooks -> New Webhook -> Copy URL. No bot or Developer Portal needed.
# Leave blank and the form just shows its local thank-you. Set it in Vercel too.
# DISCORD_FEEDBACK_WEBHOOK_URL=https://discord.com/api/webhooks/.../...
