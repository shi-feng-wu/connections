{
  "functions": {
    "api/interactions.ts": { "includeFiles": "api/_assets/**" },
    "api/join.ts": { "includeFiles": "api/_assets/**" },
    "api/refresh-card.ts": { "includeFiles": "api/_assets/**" },
    "api/cron-recap.ts": { "includeFiles": "api/_assets/**", "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }]
    }
  ]
}
