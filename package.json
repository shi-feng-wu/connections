{
  "name": "connections-activity",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "register-commands": "node --env-file=.env scripts/register-commands.mjs",
    "status": "node --env-file=.env scripts/status.mjs",
    "dashboard": "node --env-file=.env scripts/dashboard.mjs",
    "about-me": "node --env-file=.env scripts/about-me.mjs",
    "discord:entry-point": "node --env-file=.env scripts/ensure-entry-point.mjs",
    "configure-install": "node --env-file=.env scripts/configure-install.mjs",
    "test-recap": "node --env-file=.env scripts/test-recap.mjs"
  },
  "dependencies": {
    "@discord/embedded-app-sdk": "^2.5.0",
    "@napi-rs/canvas": "^1.0.0",
    "@supabase/supabase-js": "^2.106.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "^3.6.2",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.6",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.8",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.8"
  }
}
